{
  "name": "transfermarkt-clone",
  "version": "1.0.0",
  "description": "A clone of Transfermarkt - football/soccer transfer database and statistics platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "devDependencies": {
    "@prisma/client": "^7.5.0",
    "@types/node": "^20.10.0",
    "prisma": "^5.22.0",
    "typescript": "^5.3.3"
  }
}
