// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE ENTITIES
// ============================================

model Country {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String?  @map("iso_code") // ISO 3166-1 alpha-2 or alpha-3
  flagUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clubs     Club[]
  competitions Competition[]
  players   Player[]  @relation("PlayerNationality")
  birthPlace Player[] @relation("PlayerBirthPlace")

  @@map("countries")
}

model Competition {
  id          Int      @id @default(autoincrement())
  name        String
  type        CompetitionType // LEAGUE, CUP, CHAMPIONS_LEAGUE, etc.
  countryId   Int?
  country     Country? @relation(fields: [countryId], references: [id])
  externalId  String?  @unique // For integration with external APIs
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  seasons     Season[]
  clubs       ClubCompetition[]
  matches     Match[]

  @@map("competitions")
}

model Season {
  id           Int      @id @default(autoincrement())
  year         String   // e.g., "2024/2025"
  startDate    DateTime
  endDate      DateTime
  isCurrent    Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relations
  competitions Competition[]
  transfers    Transfer[]
  playerStats  PlayerStats[]
  matches      Match[]
  clubSeasons  ClubSeason[]
  clubCompetitions ClubCompetition[]
  playerClubs  PlayerClub[]

  @@unique([year])
  @@map("seasons")
}

model Club {
  id              Int      @id @default(autoincrement())
  name            String
  shortName       String?
  slug            String   @unique
  foundedYear     Int?
  stadiumName     String?
  stadiumCapacity Int?
  website         String?
  logoUrl         String?
  address         String?
  phone           String?
  email           String?
  countryId       Int
  country         Country   @relation(fields: [countryId], references: [id])
  externalId      String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  seasons         ClubSeason[]
  competitions   ClubCompetition[]
  players        PlayerClub[]
  transfersFrom  Transfer[] @relation("FromClub")
  transfersTo    Transfer[] @relation("ToClub")
  homeMatches    Match[]     @relation("HomeClub")
  awayMatches    Match[]     @relation("AwayClub")
  playerStats    PlayerStats[]
  userClubs      UserClub[]
  loanFromClub   PlayerClub[] @relation("LoanFromClub")

  @@map("clubs")
}

model Player {
  id                Int      @id @default(autoincrement())
  firstName         String
  lastName          String
  fullName          String  // Computed: concat(firstName, lastName)
  slug              String  @unique
  birthDate         DateTime
  birthPlaceId      Int?
  birthPlace        Country? @relation("PlayerBirthPlace", fields: [birthPlaceId], references: [id])
  nationalityId     Int
  nationality       Country  @relation("PlayerNationality", fields: [nationalityId], references: [id])
  height            Int?     // in cm
  weight            Int?     // in kg
  positionId        Int
  position          Position @relation(fields: [positionId], references: [id])
  foot              Foot?    // LEFT, RIGHT, BOTH
  jerseyNumber      Int?
  imageUrl          String?
  externalId        String?  @unique
  contractUntil     DateTime?
  marketValue       Float?   // Current market value in EUR
  marketValueDate   DateTime? // Last updated
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  clubs             PlayerClub[]
  transfers        Transfer[]
  stats            PlayerStats[]
  marketValues     MarketValue[]
  userPlayers      UserPlayer[]

  @@map("players")
}

model Position {
  id          Int     @id @default(autoincrement())
  name        String  @unique // "Goalkeeper", "Defender", "Midfielder", "Forward"
  category    PositionCategory // GK, DEF, MID, FWD
  createdAt   DateTime @default(now())

  // Relations
  players     Player[]

  @@map("positions")
}

// ============================================
// JUNCTION TABLES
// ============================================

model ClubSeason {
  id             Int      @id @default(autoincrement())
  clubId         Int
  club           Club     @relation(fields: [clubId], references: [id])
  seasonId       Int
  season         Season   @relation(fields: [seasonId], references: [id])
  manager        String?
  averageAge     Float?
  foreignPlayers Int?
  totalMarketValue Float?
  rank           Int?
  points        Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clubId, seasonId])
  @@map("club_seasons")
}

model ClubCompetition {
  id             Int      @id @default(autoincrement())
  clubId         Int
  club           Club     @relation(fields: [clubId], references: [id])
  competitionId  Int
  competition    Competition @relation(fields: [competitionId], references: [id])
  seasonId       Int
  season         Season   @relation(fields: [seasonId], references: [id])

  @@unique([clubId, competitionId, seasonId])
  @@map("club_competitions")
}

model PlayerClub {
  id               Int      @id @default(autoincrement())
  playerId         Int
  player           Player   @relation(fields: [playerId], references: [id])
  clubId           Int
  club             Club     @relation(fields: [clubId], references: [id])
  seasonId         Int?
  season           Season?  @relation(fields: [seasonId], references: [id])
  joinedDate       DateTime?
  leftDate         DateTime?
  contractStart    DateTime?
  contractEnd      DateTime?
  jerseyNumber     Int?
  isOnLoan         Boolean  @default(false)
  loanFromClubId   Int?
  loanFromClub     Club?    @relation("LoanFromClub", fields: [loanFromClubId], references: [id])
  loanEndDate      DateTime?
  appearances      Int?     @default(0)
  goals            Int?     @default(0)
  assists          Int?     @default(0)
  minutesPlayed    Int?     @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([playerId, clubId, seasonId])
  @@map("player_clubs")
}

// ============================================
// TRANSFER SYSTEM
// ============================================

model Transfer {
  id               Int      @id @default(autoincrement())
  playerId         Int
  player           Player   @relation(fields: [playerId], references: [id])
  fromClubId       Int
  fromClub         Club     @relation("FromClub", fields: [fromClubId], references: [id])
  toClubId         Int
  toClub           Club     @relation("ToClub", fields: [toClubId], references: [id])
  seasonId         Int
  season           Season   @relation(fields: [seasonId], references: [id])
  transferDate     DateTime
  fee              Float?   // null = free transfer
  currency         String   @default("EUR")
  type             TransferType // PERMANENT, LOAN, LOAN_WITH_OPTION, etc.
  marketValueAtTransfer Float? // Player's market value at time of transfer
  isUndisclosed   Boolean  @default(false)
  loanDuration     Int?     // Months, if loan
  optionToBuy      Boolean  @default(false)
  optionFee        Float?
  sellOnPercentage Float?   // % of future sale
  sourceUrl        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("transfers")
}

// ============================================
// STATISTICS & PERFORMANCE
// ============================================

model PlayerStats {
  id                 Int      @id @default(autoincrement())
  playerId           Int
  player             Player   @relation(fields: [playerId], references: [id])
  clubId             Int
  club               Club     @relation(fields: [clubId], references: [id])
  seasonId           Int
  season             Season   @relation(fields: [seasonId], references: [id])
  competitionType    CompetitionType
  appearances        Int      @default(0)
  starts            Int      @default(0)
  minutesPlayed      Int      @default(0)
  goals              Int      @default(0)
  assists            Int      @default(0)
  yellowCards        Int      @default(0)
  redCards           Int      @default(0)
  shots              Int      @default(0)
  shotsOnTarget      Int      @default(0)
  passes             Int      @default(0)
  keyPasses          Int      @default(0)
  tackles            Int      @default(0)
  interceptions      Int      @default(0)
  foulsDrawn         Int      @default(0)
  foulsCommitted     Int      @default(0)
  cleanSheets        Int?     @default(0) // For goalkeepers/defenders
  goalsConceded      Int?     @default(0) // For goalkeepers/defenders
  saves              Int?     @default(0) // For goalkeepers
  penaltyGoals       Int?     @default(0)
  penaltyMissed      Int?     @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([playerId, clubId, seasonId, competitionType])
  @@map("player_stats")
}

model MarketValue {
  id         Int      @id @default(autoincrement())
  playerId   Int
  player     Player   @relation(fields: [playerId], references: [id])
  value      Float    // in EUR
  currency   String   @default("EUR")
  date       DateTime
  source     String?  // e.g., "Transfermarkt", " estimation"
  createdAt  DateTime @default(now())

  @@unique([playerId, date])
  @@map("market_values")
}

// ============================================
// MATCHES & COMPETITIONS
// ============================================

model Match {
  id                 Int      @id @default(autoincrement())
  competitionId      Int
  competition        Competition @relation(fields: [competitionId], references: [id])
  seasonId           Int
  season             Season   @relation(fields: [seasonId], references: [id])
  homeClubId         Int
  homeClub           Club     @relation("HomeClub", fields: [homeClubId], references: [id])
  awayClubId         Int
  awayClub           Club     @relation("AwayClub", fields: [awayClubId], references: [id])
  matchDate          DateTime
  homeScore          Int?
  awayScore          Int?
  venue              String?
  attendance         Int?
  referee            String?
  status             MatchStatus // SCHEDULED, LIVE, FINISHED, POSTPONED
  stage              String?  // e.g., "Group Stage", "Round of 16", "Final"
  round              String?
  group              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([competitionId, seasonId, homeClubId, awayClubId, matchDate])
  @@map("matches")
}

// ============================================
// USER SYSTEM (for future features)
// ============================================

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String?
  name          String?
  role          UserRole  @default(USER)
  avatarUrl     String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  watchlistPlayers UserPlayer[]
  watchlistClubs   UserClub[]

  @@map("users")
}

model UserPlayer {
  userId     Int
  user       User   @relation(fields: [userId], references: [id])
  playerId   Int
  player     Player @relation(fields: [playerId], references: [id])
  addedAt    DateTime @default(now())

  @@unique([userId, playerId])
  @@map("user_players")
}

model UserClub {
  userId   Int
  user     User   @relation(fields: [userId], references: [id])
  clubId   Int
  club     Club   @relation(fields: [clubId], references: [id])
  addedAt  DateTime @default(now())

  @@unique([userId, clubId])
  @@map("user_clubs")
}

// ============================================
// ENUMS
// ============================================

enum CompetitionType {
  LEAGUE
  CUP
  CHAMPIONS_LEAGUE
  EUROPA_LEAGUE
  CONFERENCE_LEAGUE
  SUPER_CUP
  FRIENDLY
}

enum PositionCategory {
  GK  // Goalkeeper
  DEF // Defender
  MID // Midfielder
  FWD // Forward
}

enum Foot {
  LEFT
  RIGHT
  BOTH
}

enum TransferType {
  PERMANENT
  LOAN
  LOAN_WITH_OPTION
  LOAN_WITH_OBLIGATION
  FREE_TRANSFER
  RETIRED
  PROMOTION
  RELEGATION
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum UserRole {
  USER
  ADMIN
}