# Database
DATABASE_URL="postgresql://username:password@localhost:5432/transfermarkt_clone?connection_limit=5&pool_timeout=5"

# NextAuth.js (for future authentication)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Redis (for caching - optional for now)
REDIS_URL="redis://localhost:6379"

# App Settings
NEXT_PUBLIC_APP_NAME="Transfermarkt Clone"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Market Value Update Cron Schedule (UTC)
# Uses cron syntax: minute hour day month weekday
# Default: "0 2 * * *" (daily at 2 AM UTC)
MARKET_VALUE_UPDATE_SCHEDULE="0 2 * * *"

# External APIs (for data imports)
# TRANSFERMARKAT_API_KEY="your-api-key"
# API_FOOTBALL_KEY="your-key"